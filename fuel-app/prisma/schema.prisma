generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Raw flight data ingested from Flight Data API
model Flight {
  id                   String    @id @default(cuid())
  externalId           Int?      @unique  // ID from the Flight Data API
  flightNumber         String
  acRegistration       String
  acType               String
  deptIcao             String
  deptTime             DateTime
  arrivalIcao          String?
  arrivalTime          DateTime?
  alternateIcao        String?
  eta                  DateTime?
  fuelLoad             Float?
  dispatcher           String?
  rawData              Json?     // store the full raw API payload for reference
  ingestedAt           DateTime  @default(now())
  
  orders               FuelOrder[]
  
  @@index([deptIcao])
  @@index([deptTime])
  @@index([flightNumber])
  @@index([arrivalIcao])
}

// Fuel orders created/sent by dispatchers
model FuelOrder {
  id                   String      @id @default(cuid())
  flightId             String
  flight               Flight      @relation(fields: [flightId], references: [id])
  
  // Editable fields (may differ from flight data)
  flightNumber         String
  acRegistration       String
  acType               String
  deptIcao             String
  deptTime             DateTime
  fuelLoad             Float?
  dispatcher           String
  
  // Order tracking
  status               OrderStatus @default(PENDING)
  sentAt               DateTime?
  sentTo               String[]    // email recipients
  ccTo                 String[]    // CC recipients
  emailSubject         String?
  emailBody            String?
  
  // Update tracking
  isUpdate             Boolean     @default(false)
  originalOrderId      String?
  originalOrder        FuelOrder?  @relation("OrderUpdates", fields: [originalOrderId], references: [id])
  updates              FuelOrder[] @relation("OrderUpdates")
  updateReason         String?
  
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  
  @@index([status])
  @@index([deptIcao])
  @@index([flightNumber])
}

enum OrderStatus {
  PENDING
  SENT
  UPDATED
  CANCELLED
}

// Station email configuration
model Station {
  id                   String   @id @default(cuid())
  icaoCode             String   @unique
  name                 String?
  timezone             String?  // IANA timezone e.g. "America/Toronto"
  emails               String[] // TO recipients
  ccEmails             String[] // CC recipients
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@index([icaoCode])
}

// App-wide settings
model Setting {
  id                   String   @id @default(cuid())
  key                  String   @unique
  value                String
  updatedAt            DateTime @updatedAt
}
