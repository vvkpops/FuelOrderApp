# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@example.com
EMAIL_PASSWORD=your-app-password

# Google Sheets Configuration
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_CREDENTIALS_FILE=credentials.json

# Station Email Configuration
# Format: STATION_CODE=email1,email2,email3
STATION_JFK=fuel.jfk@example.com
STATION_LAX=fuel.lax@example.com
STATION_ORD=fuel.ord@example.com

# Additional Recipients (comma-separated)
CC_EMAILS=operations@example.com,dispatch@example.com
